# Site
NEXT_PUBLIC_SITE_URL=https://kazperkreative.com

# Supabase (submissions inbox)
# anon key is safe to expose publicly — access is gated by Row Level Security.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Cloudflare Turnstile (bot protection on the contact/join forms)
# Site key is public; secret key is server-only. If unset, forms still work
# and verification is skipped.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Email-on-new-submission via Resend (optional). If unset, no email is sent.
RESEND_API_KEY=
EMAIL_FROM=Kazper Kreative <noreply@kazperkreative.com>
EMAIL_TO=you@kazperkreative.com
