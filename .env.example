# Site
NEXT_PUBLIC_SITE_URL=https://kazperkreative.com

# Supabase (submissions inbox)
# anon key is safe to expose publicly — access is gated by Row Level Security.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Cloudflare Turnstile (bot protection on the contact/join forms)
# Site key is public; secret key is server-only. If unset, forms still work
# and verification is skipped.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Email-on-new-submission via Resend (optional). If unset, no email is sent.
RESEND_API_KEY=
EMAIL_FROM=Kazper Kreative <noreply@kazperkreative.com>
EMAIL_TO=you@kazperkreative.com

# Client billing portal (Stripe). Use TEST keys first (sk_test_/pk_test_).
# Without these, /portal still loads but Pay returns "not configured".
# The webhook also needs SUPABASE_SERVICE_ROLE_KEY set to mark invoices paid.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Service-role key (server-only) — required for the Stripe webhook to settle invoices.
SUPABASE_SERVICE_ROLE_KEY=
